# ─── Supabase ───
# Find these at https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_WITH_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# ─── AI Providers (optional — app works without them via fallback mode) ───
# Get OpenAI key: https://platform.openai.com/api-keys
# Get Gemini key: https://aistudio.google.com/apikey
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_KEY
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ─── First owner (first user to sign up with this email becomes the owner) ───
# Leave empty to auto-promote the first-ever user to owner
OWNER_EMAIL=youremail@example.com

# ─── Runtime ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=3R Digital POD
